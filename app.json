{
  "expo": {
    "name": "TiffinFlow",
    "slug": "tiffinflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "tiffinflow",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tiffinflow.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TiffinFlow uses your camera to upload payment screenshots.",
        "NSPhotoLibraryUsageDescription": "TiffinFlow accesses your photo library to upload payment screenshots.",
        "NSUserNotificationsUsageDescription": "TiffinFlow sends daily meal reminders and payment notifications.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tiffinflow.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "permissions": [
        "android.permission.NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF6B35",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-sharing",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF6B35",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TiffinFlow needs photo access to upload payment screenshots."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "07c079d1-5aec-4e0e-be06-586355bf5658"
      },
      "router": {}
    },
    "owner": "rohitpote17s-team"
  }
}
